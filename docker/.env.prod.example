# ============================================================================
# PRODUCTION DEPLOYMENT ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.prod and fill in the values below.
# WARNING: This file contains sensitive credentials. Never commit .env.prod
# to version control. Use a secure secret manager for production backups.

# ============================================================================
# DOMAIN & PUBLIC ACCESS
# ============================================================================

# The public domain/FQDN for your Paperclip instance.
# Example: paperclip.example.com
# This domain must have an A record pointing to your VPS IP address.
DOMAIN=paperclip.example.com

# Public URL for the Paperclip service (used by the app for redirects, OAuth callbacks, etc.).
# Must match your DOMAIN with https:// protocol.
# Format: https://<DOMAIN>
PAPERCLIP_PUBLIC_URL=https://paperclip.example.com

# ============================================================================
# AUTHENTICATION & SECRETS
# ============================================================================

# REQUIRED: Strong random secret for Better Auth session management.
# Generate a new one with:
#   openssl rand -base64 48
# Store this securely (e.g., in your CI/CD secrets, 1Password, etc.).
# WARNING: Changing this after deployment will invalidate all active sessions.
BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-48>

# ============================================================================
# CLAUDE AGENT AUTHENTICATION (Optional but Recommended)
# ============================================================================

# OAuth token for Claude Code Headless (Claude Max subscription only).
# Obtain this on your Mac with:
#   claude setup-token
# This token allows agents to use your Claude Max subscription instead of API keys.
# If unset, agents will require ANTHROPIC_API_KEY (paid API billing) or fail.
# WARNING: This is a sensitive credential. Rotate it if you suspect compromise.
CLAUDE_CODE_OAUTH_TOKEN=<run-claude-setup-token-on-your-mac>

# ============================================================================
# LLM PROVIDER API KEYS (All Optional)
# ============================================================================

# OpenAI API key for Codex Local adapter.
# Leave empty to disable OpenAI-based agents.
# If set, make sure your OpenAI account has quota available.
OPENAI_API_KEY=

# ============================================================================
# CADDY REVERSE PROXY (Optional)
# ============================================================================

# Cloudflare API token for DNS-01 challenge (if using Cloudflare DNS).
# Omit or leave empty to fall back to HTTP-01 challenge (standard Let's Encrypt).
# Required only if your domain's DNS is managed by Cloudflare.
CLOUDFLARE_API_TOKEN=

# ============================================================================
# NOTES
# ============================================================================

# - PORT is hardcoded to 3100 inside the container and must NOT be changed.
#   Caddy (port 80/443) reverse-proxies to paperclip:3100.
#
# - PAPERCLIP_DEPLOYMENT_MODE is set to "authenticated" (login required).
#   PAPERCLIP_DEPLOYMENT_EXPOSURE is set to "public" (internet-facing).
#   These ensure proper security for public deployments.
#
# - Do NOT set ANTHROPIC_API_KEY if using CLAUDE_CODE_OAUTH_TOKEN.
#   Setting ANTHROPIC_API_KEY switches to paid API billing and disables
#   the Claude Max subscription benefit.
#
# - The /paperclip volume persists SQLite instance data and config.
#   Back it up regularly using: docker volume export paperclip-data
#
# - Update the app with:
#   git pull origin main
#   docker compose -f docker/docker-compose.prod.yml --env-file docker/.env.prod up -d --build
