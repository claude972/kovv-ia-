# ============================================================
#  Kovv-ia — Pont Telegram — Configuration
#  Copiez ce fichier en .env et remplissez les valeurs.
#  Commande : cp tools/telegram-bridge/.env.example tools/telegram-bridge/.env
# ============================================================


# ── Telegram ──────────────────────────────────────────────

# Token du bot Telegram, obtenu auprès de @BotFather sur Telegram.
# Étapes : ouvrez @BotFather → /newbot → suivez les instructions → copiez le token.
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlMnOpQrStUvWxYz

# (Optionnel mais FORTEMENT recommandé) Liste blanche des chat IDs autorisés,
# séparés par des virgules. Si vide, tout utilisateur Telegram peut écrire au bot.
# Pour connaître votre chat ID : démarrez le bot et envoyez /id
# Exemple avec plusieurs IDs : 123456789,987654321
TELEGRAM_ALLOWED_CHAT_IDS=


# ── Kovv-ia API ───────────────────────────────────────────

# URL de base de l'API Kovv-ia (ne pas modifier si vous utilisez le port par défaut).
KOVV_API=http://127.0.0.1:3100/api

# Identifiant de l'entreprise dans Kovv-ia.
# Pour trouver cet ID : node tools/telegram-bridge/bridge.mjs --list
KOVV_COMPANY_ID=votre-company-id-ici

# Identifiant de l'agent qui répondra aux messages Telegram.
# Pour trouver cet ID : node tools/telegram-bridge/bridge.mjs --list
KOVV_AGENT_ID=votre-agent-id-ici

# (Optionnel) Identifiant du projet auquel rattacher les conversations.
# Laissez vide si vous ne souhaitez pas associer un projet.
# Pour trouver cet ID : node tools/telegram-bridge/bridge.mjs --list
KOVV_PROJECT_ID=


# ── Comportement du pont ──────────────────────────────────

# Intervalle en millisecondes entre chaque vérification des réponses de l'agent.
# Valeur par défaut : 3000 ms (3 secondes). Minimum recommandé : 2000 ms.
POLL_INTERVAL_MS=3000

# Chemin du fichier de sauvegarde de l'état du pont (conversations en cours).
# Ce fichier est créé automatiquement ; inutile de le créer manuellement.
STATE_FILE=tools/telegram-bridge/state.json
